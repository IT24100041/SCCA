{
  "info": {
    "name": "SPARKLENZ Backend CRUD",
    "description": "Postman collection for SPARKLENZ MERN backend CRUD APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "userId", "value": "" },
    { "key": "packageId", "value": "" },
    { "key": "subscriptionId", "value": "" },
